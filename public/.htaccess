<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Legacy URL redirects (SEO)
  RewriteRule ^includes/egp/TTI_V1/?$ /services [R=301,L]
  RewriteRule ^includes/egp/LTM_V1/?$ /services [R=301,L]
  
  # Disable Multiviews to prevent conflicts with rewriting
  Options -MultiViews
  
  # Allow access to existing files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Rewrite everything else to index.html
  RewriteRule ^ index.html [QSA,L]
</IfModule>

<IfModule mod_headers.c>
    # Optional: Security headers, but avoiding strict blocking for now
    Header set X-Content-Type-Options "nosniff"
</IfModule>
